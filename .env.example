# Hugging Face Token (https://huggingface.co/settings/tokens)
# Wird für pyannote-Diarization-Modelle benötigt.
# Vorher Lizenz akzeptieren auf:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=hf_xxx

# Whisper-Modellgröße: tiny | base | small | medium | large-v2 | large-v3
WHISPER_MODEL=large-v3

# cuda | cpu
DEVICE=cuda

# float16 (GPU) | int8 (CPU) | float32
COMPUTE_TYPE=float16

# Batchgröße für faster-whisper (kleiner = weniger VRAM)
BATCH_SIZE=16

# Standardsprache (None = Auto-Detect). Beispiel: de, en
DEFAULT_LANGUAGE=de

# Speaker-Datenbank (SQLite-Datei)
SPEAKER_DB=speakers.db

# Cosine-Similarity-Schwelle für Speaker-Match (0.0–1.0).
# Niedriger = mehr Treffer, mehr Verwechslungen. Typisch 0.45–0.65 für ECAPA.
MATCH_THRESHOLD=0.50
